{
  "manifest_version": 3,
  "name": "Pinterest Pastel Theme",
  "version": "1.0",
  "description": "Geef Pinterest een lichtroze, wit en lichtbeige thema.",
  "content_scripts": [
    {
      "matches": [
        "https://www.pinterest.com/*",
        "https://www.pinterest.nl/*",
        "https://www.pinterest.de/*",
        "https://www.pinterest.co.uk/*",
        "https://www.pinterest.fr/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}